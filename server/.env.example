# Copy to .env and adjust to your local Ollama setup.
# .env is gitignored.

# Ollama HTTP API base URL.
# - With Docker stack (`docker compose up`): the api container reads OLLAMA_HOST
#   from docker-compose.yml directly, so this file is ignored in that flow.
# - For running uvicorn locally against a local Ollama on the host:
#     OLLAMA_HOST=http://localhost:11434
# - For running uvicorn locally against the Docker Ollama:
#     OLLAMA_HOST=http://localhost:11434  (docker-compose maps host:11434 → container:11434)
OLLAMA_HOST=http://localhost:11434

# Any chat-capable model from `ollama list`.
# Recommended: qwen2.5:7b (good tool calling, ~5 GB).
OLLAMA_MODEL=qwen2.5:7b
